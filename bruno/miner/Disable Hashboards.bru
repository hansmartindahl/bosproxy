meta {
  name: Disable Hashboards
  type: http
  seq: 8
}

post {
  url: http://localhost:8080/miner/disable-hashboards
  body: json
  auth: inherit
}

headers {
  Authorization: {{AUTHORIZATION}}
}

body:json {
  {
    "saveAction": "SAVE_ACTION_SAVE_AND_APPLY",
    "hashboardIds": ["0", "1"]
  }
}

settings {
  encodeUrl: true
}
