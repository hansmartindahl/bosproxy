meta {
  name: Set Default Hashrate Target
  type: http
  seq: 7
}

post {
  url: http://localhost:8080/performance/set-default-hashrate-target
  body: json
  auth: inherit
}

headers {
  Authorization: {{AUTHORIZATION}}
}

body:json {
  {
    "saveAction": "SAVE_ACTION_SAVE_AND_APPLY",
    "hashrateTargetThs": 100.0
  }
}

settings {
  encodeUrl: true
}
