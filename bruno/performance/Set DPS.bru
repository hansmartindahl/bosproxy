meta {
  name: Set DPS
  type: http
  seq: 11
}

post {
  url: http://localhost:8080/performance/set-dps
  body: json
  auth: inherit
}

headers {
  Authorization: {{AUTHORIZATION}}
}

body:json {
  {
    "saveAction": "SAVE_ACTION_SAVE_AND_APPLY",
    "enable": true,
    "enableShutdown": false,
    "shutdownDurationHours": 1,
    "mode": "DPS_MODE_SLEEP"
  }
}

settings {
  encodeUrl: true
}
