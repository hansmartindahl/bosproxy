meta {
  name: Decrement Power Target
  type: http
  seq: 6
}

post {
  url: http://localhost:8080/performance/decrement-power-target
  body: json
  auth: inherit
}

headers {
  Authorization: {{AUTHORIZATION}}
}

body:json {
  {
    "saveAction": "SAVE_ACTION_SAVE_AND_APPLY",
    "powerTargetWatt": 100
  }
}

settings {
  encodeUrl: true
}
