meta {
  name: Set Default Power Target
  type: http
  seq: 3
}

post {
  url: http://localhost:8080/performance/set-default-power-target
  body: json
  auth: inherit
}

headers {
  Authorization: {{AUTHORIZATION}}
}

body:json {
  {
    "saveAction": "SAVE_ACTION_SAVE_AND_APPLY",
    "powerTargetWatt": 3000
  }
}

settings {
  encodeUrl: true
}
